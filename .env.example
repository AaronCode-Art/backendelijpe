# 1. Crea un proyecto gratis en https://neon.tech
# 2. Copia el "Connection string" (botón Connect) y pégalo aquí:
DATABASE_URL=postgresql://usuario:password@ep-xxxx.neon.tech/elijepdb?sslmode=require

# 3. IA gratuita del chat de orientación (recomendado: Groq)
#    - Crea cuenta gratis en https://console.groq.com (no pide tarjeta)
#    - Ve a "API Keys" -> "Create API Key" y pega la key aquí:
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 4. Dominio(s) del frontend permitidos para llamar a esta API (CORS).
#    En local usa http://localhost:5173 (Vite). En Render pon la URL pública
#    de tu frontend, ej: https://elijepe-front.onrender.com
#    Puedes poner varios separados por coma.
FRONTEND_URL=http://localhost:5173
